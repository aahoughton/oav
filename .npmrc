# Disable auto-install-peers so the framework adapters' peer-dep
# declarations (`express`, `fastify`) do not pull those packages into
# the main workspace's pnpm-lock.yaml. Each adapter's runtime
# integration tests live in framework-tests/ (an isolated pnpm root
# that owns its own copy of the framework). See issue #295.
#
# The exception is `fastify`, which oav-fastify keeps as a real devDep
# because there is no @types/fastify on DefinitelyTyped; tsc needs the
# fastify package itself to resolve `import type { FastifyRequest }`
# in oav-fastify/src/*.ts.
auto-install-peers=false
