{
  "name": "@oav/spec",
  "version": "0.0.0",
  "description": "OpenAPI 3.1 spec loader, multi-file resolver, and overlay merger for @oav.",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@oav/core": "workspace:*",
    "@oav/schema": "workspace:*",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
