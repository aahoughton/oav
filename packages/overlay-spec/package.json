{
  "name": "@oav/overlay-spec",
  "version": "0.0.0",
  "private": true,
  "description": "Internal: translator from OpenAPI Overlay 1.0 spec-format documents to @oav/spec's typed SpecOverlay.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@oav/core": "workspace:*",
    "@oav/spec": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
