{
  "name": "@aahoughton/oav",
  "version": "2.1.0",
  "description": "HTTP-aware OpenAPI request/response validator. Batteries-included distribution: re-exports @aahoughton/oav-core, adds YAML readers, ships the `oav` CLI. For a zero-runtime-dep install, use @aahoughton/oav-core directly.",
  "keywords": [
    "cli",
    "http",
    "json-schema",
    "json-schema-2020-12",
    "openapi",
    "openapi-3.0",
    "openapi-3.1",
    "openapi-3.2",
    "openapi3",
    "schema",
    "validation",
    "validator",
    "yaml"
  ],
  "homepage": "https://github.com/aahoughton/oav#readme",
  "bugs": {
    "url": "https://github.com/aahoughton/oav/issues"
  },
  "license": "MIT",
  "author": "Andrew Houghton <aah@roarmouse.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aahoughton/oav.git",
    "directory": "packages/oav"
  },
  "bin": {
    "oav": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schema.d.ts",
        "default": "./dist/schema.js"
      },
      "require": {
        "types": "./dist/schema.d.cts",
        "default": "./dist/schema.cjs"
      }
    },
    "./schema/internals": {
      "import": {
        "types": "./dist/schema-internals.d.ts",
        "default": "./dist/schema-internals.js"
      },
      "require": {
        "types": "./dist/schema-internals.d.cts",
        "default": "./dist/schema-internals.cjs"
      }
    },
    "./spec": {
      "import": {
        "types": "./dist/spec.d.ts",
        "default": "./dist/spec.js"
      },
      "require": {
        "types": "./dist/spec.d.cts",
        "default": "./dist/spec.cjs"
      }
    },
    "./formats": {
      "import": {
        "types": "./dist/formats.d.ts",
        "default": "./dist/formats.js"
      },
      "require": {
        "types": "./dist/formats.d.cts",
        "default": "./dist/formats.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./validator/internals": {
      "import": {
        "types": "./dist/validator-internals.d.ts",
        "default": "./dist/validator-internals.js"
      },
      "require": {
        "types": "./dist/validator-internals.d.cts",
        "default": "./dist/validator-internals.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "prepack": "node -e \"if((process.env.npm_config_user_agent||'').startsWith('npm/'))throw Error('Use pnpm pack: npm pack does not rewrite workspace:* deps.')\" && tsup"
  },
  "dependencies": {
    "@aahoughton/oav-core": "workspace:*",
    "commander": "^14.0.0",
    "esbuild": "^0.28.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@oav/cli": "workspace:*",
    "@oav/core": "workspace:*",
    "@oav/formats": "workspace:*",
    "@oav/schema": "workspace:*",
    "@oav/spec": "workspace:*",
    "@oav/validator": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "//": "No prepublishOnly: release.yml runs `pnpm test` from root before `pnpm -r publish`. Per-package publish (`cd packages/<x> && pnpm publish`) is not the supported path; it would skip the test gate."
}
