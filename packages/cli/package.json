{
  "name": "@oav/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Internal: CLI entrypoint for oav. Not published — installed as the `oav` binary from the top-level package.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@oav/core": "workspace:*",
    "@oav/spec": "workspace:*",
    "@oav/validator": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
