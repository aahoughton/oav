{
  "name": "@aahoughton/oav",
  "version": "1.0.0",
  "description": "HTTP-aware OpenAPI request/response validator with a JSON Schema codegen compiler.",
  "keywords": [
    "cli",
    "http",
    "json-schema",
    "json-schema-2020-12",
    "openapi",
    "openapi-3.0",
    "openapi-3.1",
    "openapi-3.2",
    "openapi3",
    "schema",
    "validation",
    "validator"
  ],
  "homepage": "https://github.com/aahoughton/oav#readme",
  "bugs": {
    "url": "https://github.com/aahoughton/oav/issues"
  },
  "license": "MIT",
  "author": "Andrew Houghton <aah@roarmouse.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aahoughton/oav.git"
  },
  "bin": {
    "oav": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    },
    "./spec": {
      "types": "./dist/spec.d.ts",
      "import": "./dist/spec.js",
      "require": "./dist/spec.cjs"
    },
    "./formats": {
      "types": "./dist/formats.d.ts",
      "import": "./dist/formats.js",
      "require": "./dist/formats.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxfmt --check .",
    "fmt": "oxfmt --write .",
    "typecheck": "tsc -b",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "commander": "14.0.3",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "commander": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "commander": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
