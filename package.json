{
  "name": "oav",
  "version": "0.0.0",
  "private": true,
  "description": "OpenAPI 3.1 HTTP request/response validator",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && oxfmt --check .",
    "fmt": "oxfmt --write .",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
