[
  {
    "name": "GET /pets — no query, valid",
    "kind": "request",
    "method": "GET",
    "path": "/pets",
    "expect": "valid"
  },
  {
    "name": "GET /pets — limit=50, valid",
    "kind": "request",
    "method": "GET",
    "path": "/pets",
    "query": { "limit": "50" },
    "expect": "valid"
  },
  {
    "name": "GET /pets — limit=0 violates minimum",
    "kind": "request",
    "method": "GET",
    "path": "/pets",
    "query": { "limit": "0" },
    "expect": "invalid",
    "expectCodes": ["minimum"]
  },
  {
    "name": "POST /pets — valid body",
    "kind": "request",
    "method": "POST",
    "path": "/pets",
    "contentType": "application/json",
    "body": { "name": "Fido" },
    "expect": "valid"
  },
  {
    "name": "POST /pets — missing name",
    "kind": "request",
    "method": "POST",
    "path": "/pets",
    "contentType": "application/json",
    "body": { "tag": "dog" },
    "expect": "invalid",
    "expectCodes": ["required"]
  },
  {
    "name": "POST /pets — empty body is an error (required body)",
    "kind": "request",
    "method": "POST",
    "path": "/pets",
    "contentType": "application/json",
    "expect": "invalid",
    "expectCodes": ["body"]
  },
  {
    "name": "POST /pets — wrong Content-Type",
    "kind": "request",
    "method": "POST",
    "path": "/pets",
    "contentType": "text/plain",
    "body": "raw",
    "expect": "invalid",
    "expectCodes": ["content-type"]
  },
  {
    "name": "GET /pets/42 — valid path param",
    "kind": "request",
    "method": "GET",
    "path": "/pets/42",
    "expect": "valid"
  },
  {
    "name": "GET /pets/abc — path param not an integer",
    "kind": "request",
    "method": "GET",
    "path": "/pets/abc",
    "expect": "invalid",
    "expectCodes": ["type"]
  },
  {
    "name": "GET /pets/0 — path param below minimum",
    "kind": "request",
    "method": "GET",
    "path": "/pets/0",
    "expect": "invalid",
    "expectCodes": ["minimum"]
  },
  {
    "name": "response GET /pets 200 — valid",
    "kind": "response",
    "method": "GET",
    "path": "/pets",
    "status": 200,
    "contentType": "application/json",
    "body": [{ "id": 1, "name": "Fido" }],
    "expect": "valid"
  },
  {
    "name": "response GET /pets 200 — item missing id",
    "kind": "response",
    "method": "GET",
    "path": "/pets",
    "status": 200,
    "contentType": "application/json",
    "body": [{ "name": "Fido" }],
    "expect": "invalid",
    "expectCodes": ["required"]
  },
  {
    "name": "response GET /pets/42 — 404 undeclared body schema but status ok",
    "kind": "response",
    "method": "GET",
    "path": "/pets/42",
    "status": 404,
    "expect": "valid"
  },
  {
    "name": "response GET /pets/42 — 500 undeclared status",
    "kind": "response",
    "method": "GET",
    "path": "/pets/42",
    "status": 500,
    "expect": "invalid",
    "expectCodes": ["status"]
  }
